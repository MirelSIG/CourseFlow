@startuml

title Secuencia - Flujo General CourseFlow

actor Usuario
actor Admin
participant "Frontend" as FE
participant "API" as API
participant "AuthService" as AUTH
participant "CourseService" as COURSE
participant "ApplicationService" as APP
database "DB" as DB

alt Usuario registrado
  Usuario -> FE: Inicia sesion
  FE -> API: POST /auth/login
  API -> AUTH: validarCredenciales()
  AUTH -> DB: SELECT user
  DB --> AUTH: datos usuario
  AUTH --> API: usuario valido + token
  API --> FE: 200 OK + JWT
else Usuario no registrado
  Usuario -> FE: Se registra
  FE -> API: POST /auth/register
  API -> AUTH: registrarUsuario()
  AUTH -> DB: INSERT user
  DB --> AUTH: usuario creado
  AUTH --> API: registro exitoso
  API --> FE: 201 Created
end

Usuario -> FE: Consulta cursos disponibles
FE -> API: GET /courses
API -> COURSE: listarCursosActivos()
COURSE -> DB: SELECT courses active
DB --> COURSE: cursos activos
COURSE --> API: listado cursos
API --> FE: 200 OK + cursos

opt Usuario desea inscribirse
  Usuario -> FE: Envia solicitud de inscripcion
  FE -> API: POST /applications
  API -> APP: crearSolicitud(Pendiente)
  APP -> DB: INSERT application
  DB --> APP: solicitud creada
  APP --> API: solicitud pendiente
  API --> FE: 201 Created
end

Admin -> FE: Revisa solicitudes pendientes
FE -> API: GET /applications?status=Pendiente
API -> APP: listarPendientes()
APP -> DB: SELECT applications pendientes
DB --> APP: solicitudes pendientes
APP --> API: solicitudes
API --> FE: 200 OK

alt Admin acepta
  Admin -> FE: Aceptar solicitud
  FE -> API: PATCH /applications/{id}/accept
  API -> APP: actualizarEstado(Aceptado)
  APP -> DB: UPDATE status = Aceptado
  DB --> APP: actualizado
  APP --> API: ok
  API --> FE: 200 OK
else Admin rechaza
  Admin -> FE: Rechazar solicitud
  FE -> API: PATCH /applications/{id}/reject
  API -> APP: actualizarEstado(Rechazado)
  APP -> DB: UPDATE status = Rechazado
  DB --> APP: actualizado
  APP --> API: ok
  API --> FE: 200 OK
end

Usuario -> FE: Consulta estado de su solicitud
FE -> API: GET /applications/me
API -> APP: listarPorUsuario()
APP -> DB: SELECT applications by user
DB --> APP: solicitudes del usuario
APP --> API: estado actual
API --> FE: 200 OK + estado
FE --> Usuario: Muestra estado final

@enduml
