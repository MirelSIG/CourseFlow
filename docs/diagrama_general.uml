@startuml
start
:Usuario accede a la plataforma;
if (Está registrado?) then (Sí)
  :Login;
else (No)
  :Registro;
endif

:Ver cursos disponibles;

if (Usuario quiere inscribirse?) then (Sí)
  :Enviar solicitud;
  :Solicitud queda en estado "Pendiente";
endif

:Admin revisa solicitudes;

if (Admin acepta?) then (Sí)
  :Cambiar estado a "Aceptado";
else (No)
  :Cambiar estado a "Rechazado";
endif

:Usuario consulta estado;
stop
@enduml
