@startuml

title Secuencia - Gestion de Solicitudes

actor Usuario
actor Admin
participant "Frontend" as FE
participant "API" as API
participant "ApplicationService" as APP
database "DB" as DB
participant "NotificationService" as NOTIF

Usuario -> FE: Solicita participar en un curso
FE -> API: POST /applications
API -> APP: crearSolicitud(userId, courseId)
APP -> DB: INSERT application (Pendiente)
DB --> APP: solicitud creada
APP --> API: solicitud pendiente
API --> FE: 201 Created
FE --> Usuario: Solicitud enviada

Admin -> FE: Revisa solicitudes
FE -> API: GET /applications
API -> APP: listarSolicitudes()
APP -> DB: SELECT applications
DB --> APP: listado solicitudes
APP --> API: listado solicitudes
API --> FE: 200 OK

alt Aceptar solicitud
  Admin -> FE: Aceptar candidato
  FE -> API: PATCH /applications/{id}/accept
  API -> APP: actualizarEstado(id, "Aceptado")
  APP -> DB: UPDATE status = Aceptado
  DB --> APP: actualizado
  APP -> NOTIF: notificarUsuario(id, "Aceptado")
  NOTIF --> APP: notificacion enviada
  APP --> API: resultado
  API --> FE: 200 OK
else Rechazar solicitud
  Admin -> FE: Rechazar candidato
  FE -> API: PATCH /applications/{id}/reject
  API -> APP: actualizarEstado(id, "Rechazado")
  APP -> DB: UPDATE status = Rechazado
  DB --> APP: actualizado
  APP -> NOTIF: notificarUsuario(id, "Rechazado")
  NOTIF --> APP: notificacion enviada
  APP --> API: resultado
  API --> FE: 200 OK
end

FE --> Usuario: Estado actualizado de la solicitud

@enduml
