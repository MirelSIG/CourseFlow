@startuml
start
:Admin accede al panel;
:Ver listado de cursos;

if (Crear curso?) then (Sí)
  :Formulario nuevo curso;
  :Guardar en BBDD;
endif

if (Editar curso?) then (Sí)
  :Modificar datos;
  :Actualizar en BBDD;
endif

if (Desactivar curso?) then (Sí)
  :Cambiar is_active = false;
endif

stop
@enduml
