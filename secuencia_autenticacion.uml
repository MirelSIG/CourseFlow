@startuml

title Secuencia - Autenticacion

actor Usuario
participant "Frontend" as FE
participant "API" as API
participant "AuthService" as AUTH
database "DB" as DB

Usuario -> FE: Envia email y password
FE -> API: POST /auth/login
API -> AUTH: validarCredenciales(email, password)
AUTH -> DB: SELECT user by email
DB --> AUTH: user + hash password

alt Credenciales validas
  AUTH --> API: usuario validado
  API -> AUTH: generarJWT(user)
  AUTH --> API: token JWT
  API --> FE: 200 OK + token
  FE --> Usuario: Login exitoso
else Credenciales invalidas
  AUTH --> API: error autenticacion
  API --> FE: 401 Unauthorized
  FE --> Usuario: Mostrar error de autenticacion
end

@enduml
